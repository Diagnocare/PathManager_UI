<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Always serve index.html; never show a directory listing -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <directoryBrowse enabled="false" />

    <!--
      Redirect all 404s back to index.html so Angular's client-side router
      can handle the URL. This does NOT require the URL Rewrite IIS module.
    -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/index.html" responseMode="ExecuteURL" />
    </httpErrors>

    <!-- Ensure modern web assets are served with correct MIME types -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

  </system.webServer>
</configuration>
